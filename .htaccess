# ============================================================
#  OMUGWO — Apache .htaccess
#  omugwoapp.com — Apache 2.4+ / cPanel shared hosting
# ============================================================

Options -Indexes
Options +FollowSymLinks
RewriteEngine On


# ================================================================
# 1. FORCE HTTPS
# ================================================================
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]


# ================================================================
# 2. FORCE NON-WWW
# ================================================================
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^ https://%1%{REQUEST_URI} [R=301,L]


# ================================================================
# 3. PASSTHROUGH — never rewrite these critical files
#    robots.txt and sitemap.xml must be served as-is
# ================================================================
RewriteRule ^robots\.txt$  - [L]
RewriteRule ^sitemap\.xml$ - [L]
RewriteRule ^sitemap\.xsl$ - [L]


# ================================================================
# 4. CLEAN URLs — strip .html extension
# ================================================================

# Pass through real files and directories (css, js, images, etc.)
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Redirect browser if .html appears in URL bar (301 permanent)
RewriteCond %{THE_REQUEST} \s/(.+)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# Internally serve the .html file when no extension is present
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+?)/?$ $1.html [L]


# ================================================================
# 5. REMOVE TRAILING SLASH from page URLs
# ================================================================
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{THE_REQUEST} \s(.+?)/+[\s?]
RewriteRule ^ %1 [R=301,L]


# ================================================================
# 6. CUSTOM ERROR PAGES
# ================================================================
ErrorDocument 404 /404.html
ErrorDocument 403 /index.html
ErrorDocument 500 /index.html


# ================================================================
# 7. SECURITY HEADERS
# ================================================================
<IfModule mod_headers.c>

  # Clickjacking protection
  Header always set X-Frame-Options "SAMEORIGIN"

  # Prevent MIME sniffing
  Header always set X-Content-Type-Options "nosniff"

  # XSS protection for older browsers
  Header always set X-XSS-Protection "1; mode=block"

  # Referrer policy
  Header always set Referrer-Policy "strict-origin-when-cross-origin"

  # Disable browser features not used by this site
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), usb=(), interest-cohort=()"

  # Content Security Policy
  # - Allows Google Fonts (googleapis + gstatic)
  # - Allows Formspree for form submissions (connect-src + form-action)
  # - Allows inline styles/scripts (required for this static site)
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://formspree.io; form-action 'self' https://formspree.io; frame-ancestors 'none'; base-uri 'self';"

  # HSTS — forces HTTPS for 1 year (browsers will cache this)
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

  # Remove server signature from responses
  Header always unset X-Powered-By
  Header always unset Server

</IfModule>


# ================================================================
# 8. BROWSER CACHING
# ================================================================
<IfModule mod_expires.c>
  ExpiresActive On

  # HTML — short so updates deploy quickly
  ExpiresByType text/html                   "access plus 1 hour"

  # CSS & JS — long cache; add ?v=2 query string on deploy to bust
  ExpiresByType text/css                    "access plus 1 year"
  ExpiresByType application/javascript      "access plus 1 year"
  ExpiresByType text/javascript             "access plus 1 year"

  # Images
  ExpiresByType image/jpeg                  "access plus 1 year"
  ExpiresByType image/png                   "access plus 1 year"
  ExpiresByType image/gif                   "access plus 1 year"
  ExpiresByType image/webp                  "access plus 1 year"
  ExpiresByType image/svg+xml               "access plus 1 year"
  ExpiresByType image/x-icon                "access plus 1 year"

  # Fonts
  ExpiresByType font/woff                   "access plus 1 year"
  ExpiresByType font/woff2                  "access plus 1 year"
  ExpiresByType application/font-woff       "access plus 1 year"
  ExpiresByType application/font-woff2      "access plus 1 year"

  # XML / sitemap
  ExpiresByType application/xml             "access plus 1 day"
  ExpiresByType text/xml                    "access plus 1 day"

  # Fallback
  ExpiresDefault                            "access plus 1 month"
</IfModule>

# Cache-Control headers (supplements Expires)
<IfModule mod_headers.c>
  <FilesMatch "\.(css|js|woff|woff2|jpg|jpeg|png|gif|webp|svg|ico)$">
    Header append Cache-Control "public, immutable"
  </FilesMatch>
  <FilesMatch "\.(html|htm)$">
    Header set Cache-Control "public, max-age=3600, must-revalidate"
  </FilesMatch>
  <FilesMatch "\.(xml|txt)$">
    Header set Cache-Control "public, max-age=86400"
  </FilesMatch>
</IfModule>


# ================================================================
# 9. GZIP COMPRESSION
# ================================================================
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html
  AddOutputFilterByType DEFLATE text/css
  AddOutputFilterByType DEFLATE text/javascript
  AddOutputFilterByType DEFLATE application/javascript
  AddOutputFilterByType DEFLATE application/json
  AddOutputFilterByType DEFLATE application/xml
  AddOutputFilterByType DEFLATE text/xml
  AddOutputFilterByType DEFLATE image/svg+xml
  AddOutputFilterByType DEFLATE font/woff
  AddOutputFilterByType DEFLATE font/woff2

  # Don't compress already-compressed formats
  SetEnvIfNoCase Request_URI \.(gz|br|zip|png|jpg|jpeg|gif|webp|ico|woff|woff2)$ no-gzip
</IfModule>


# ================================================================
# 10. PROTECT SENSITIVE FILES
# ================================================================

# Block all dotfiles (.htaccess, .env, .git, etc.)
<FilesMatch "^\.">
  Order allow,deny
  Deny from all
</FilesMatch>

# Block dangerous file types
<FilesMatch "\.(env|log|sql|bak|sh|bash|lock|gitignore|config|ini|yml|yaml|json|md|pem|key|crt|cert)$">
  Order allow,deny
  Deny from all
</FilesMatch>

# Block backup and temporary files
<FilesMatch "\.(~|#.*#|\.swp|\.swo)$">
  Order allow,deny
  Deny from all
</FilesMatch>

# Block access to README
<FilesMatch "^(README|CHANGELOG|LICENSE)(\..*)?$">
  Order allow,deny
  Deny from all
</FilesMatch>


# ================================================================
# 11. BLOCK BAD BOTS & COMMON ATTACK PATTERNS
# ================================================================
<IfModule mod_rewrite.c>
  # Block requests with no User-Agent (common scanners)
  RewriteCond %{HTTP_USER_AGENT} ^$ [NC]
  RewriteRule .* - [F,L]

  # Block common vulnerability scanners
  RewriteCond %{HTTP_USER_AGENT} (sqlmap|nikto|nmap|masscan|zgrab|nuclei|dirbuster|gobuster|wfuzz|ffuf) [NC]
  RewriteRule .* - [F,L]

  # Block common SQL injection patterns in URL
  RewriteCond %{QUERY_STRING} (union.*select|select.*from|insert.*into|drop.*table) [NC]
  RewriteRule .* - [F,L]

  # Block XSS patterns in URL
  RewriteCond %{QUERY_STRING} (<script|javascript:|vbscript:|onload=|onerror=) [NC]
  RewriteRule .* - [F,L]
</IfModule>


# ================================================================
# 12. MIME TYPES
# ================================================================
<IfModule mod_mime.c>
  AddType text/css                .css
  AddType application/javascript  .js
  AddType image/svg+xml           .svg
  AddType image/webp              .webp
  AddType font/woff               .woff
  AddType font/woff2              .woff2
  AddType application/xml         .xml
  AddType text/plain              .txt
</IfModule>


# ================================================================
# 13. DISABLE ETags + CHARSET
# ================================================================
<IfModule mod_headers.c>
  Header unset ETag
</IfModule>
FileETag None
AddDefaultCharset UTF-8


# ================================================================
# 14. PREVENT HOTLINKING of images
# ================================================================
<IfModule mod_rewrite.c>
  RewriteCond %{HTTP_REFERER} !^$
  RewriteCond %{HTTP_REFERER} !^https://(www\.)?omugwoapp\.com [NC]
  RewriteRule \.(jpg|jpeg|png|gif|webp|svg)$ - [F,L]
</IfModule>
